{
  "name": "teenz-report",
  "version": "1.0.0",
  "description": "링키영어 재원생 학습 리포트 공유 시스템",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"nodemon server.js\" \"cd client && npm run dev\"",
    "dev:server": "nodemon server.js",
    "build": "cd client && npm install && npm run build",
    "seed": "node db/seed.js",
    "setup": "node db/setup.js && node db/seed.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.3"
  }
}
